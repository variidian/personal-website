    <li>- art! i mostly draw digitally on <a href="https://procreate.com/">procreate</a>, however i sometimes make some stuff on clothing :]</a></li>
    <li id="lastfm_Text">- music! <s>not an addict</s> currently, i'm not listening to anything.</li>
  </ul>
  <p><i id="funfact">fun fact</i></p>
  <p></p>
</div>
<script>
const response = await fetch('/api/lastfm');
const data = await response.json();
const latestTrack = data.recenttracks.track[0];
if (latestTrack['@attr'].nowplaying === 'true') {
  document.getElementById("lastfm_Text").innerHTML = `- music! infact, i'm currently listening to <i>${latestTrack.name} by ${latestTrack.artist['#text']}.</i>`;
}
const options = ["fun fact: my username 'variidian' is a misspelling of the colour viridian green :]","fun fact: my favo(u)rite colour is green :>","fun fact: Some Fun Fact(tm)"]
const randomIndex = Math.floor(Math.random() * options.length);
document.getElementById("funfact").innerHTML= options[randomIndex];
</script>
<script src="../styles/js.js"></script> 
<div id="cursor"></div>